#!/usr/bin/env bash
#
# claudeview-open — open the viewer as a dedicated, chromeless, full-screen
# browser instance, suitable for pinning to a second (portrait) monitor.
#
# It uses its own profile directory, so it stays separate from your everyday
# browser. The first Chromium-family browser found is used.
#
# Config via environment (all optional):
#   CLAUDEVIEW_URL      viewer URL              (default http://localhost:4790)
#   CLAUDEVIEW_POS      window position "x,y"   (default 0,0 — top-left corner,
#                                                i.e. wherever your portrait
#                                                monitor sits in the layout)
#   CLAUDEVIEW_PROFILE  dedicated profile dir   (default ~/.claudeview-profile)

set -euo pipefail

url="${CLAUDEVIEW_URL:-http://localhost:4790}"
pos="${CLAUDEVIEW_POS:-0,0}"
profile="${CLAUDEVIEW_PROFILE:-$HOME/.claudeview-profile}"

# PATH names first (Linux), then the fixed macOS bundle paths (Chrome et al. are
# never on PATH there). All are Chromium-family, so the exec block below — with
# its --app / --user-data-dir / window flags — is identical whichever we find.
for candidate in \
  google-chrome google-chrome-stable chromium chromium-browser brave-browser \
  "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome" \
  "/Applications/Chromium.app/Contents/MacOS/Chromium" \
  "/Applications/Brave Browser.app/Contents/MacOS/Brave Browser" \
  "/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge"; do
  if command -v "$candidate" >/dev/null 2>&1 || [ -x "$candidate" ]; then
    browser="$candidate"
    break
  fi
done

if [ -z "${browser:-}" ]; then
  echo "claudeview-open: no Chromium-family browser found (need --app support)." >&2
  exit 1
fi

exec "$browser" \
  --user-data-dir="$profile" \
  --app="$url" \
  --window-position="$pos" \
  --start-fullscreen
