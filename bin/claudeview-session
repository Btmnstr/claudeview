#!/usr/bin/env bash
#
# claudeview-session — print the ClaudeView session key for the current dir.
#
# It calls the same function the hook uses, so a manual write lands in the hook's
# group instead of a group of its own:
#
#   ~/.claudeview/$(claudeview-session)~review.md   ->   <repo>~<branch>~review.md
#
# Install by symlinking onto your PATH, e.g.:
#   ln -s "$PWD/bin/claudeview-session" ~/.local/bin/

set -euo pipefail

# Resolve a possibly-symlinked path to the directory that holds its target.
# Portable (GNU + BSD/macOS): follows symlink chains with plain `readlink`, since
# `readlink -f` is GNU-only. Twinned in hooks/claudeview-push, which must locate
# the same lib before it can source it — so the resolver can't live in the lib.
resolve_dir() {
  local src="$1" dir
  while [ -L "$src" ]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    case "$src" in /*) ;; *) src="$dir/$src" ;; esac
  done
  cd -P "$(dirname "$src")" && pwd
}

# resolve_dir lands in bin/; the lib is one level up under hooks/.
# shellcheck source=hooks/claudeview-lib.sh
source "$(dirname "$(resolve_dir "${BASH_SOURCE[0]}")")/hooks/claudeview-lib.sh"

cv_session_key "$PWD"
