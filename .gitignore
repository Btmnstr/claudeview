# Runtime content (each .md becomes a tab); keep only the seed tab.
content/*
!content/welcome.md

# Build artifacts (produced inside Docker).
server/_build/
server/deps/
server/tmp/
web/elm-stuff/
web/elm.js
*.beam

# Local, machine-specific Claude Code permissions.
.claude/settings.local.json

# Downloaded code-quality tools (fetched by `make tools`).
.tools/

# Playwright MCP scratch output.
.playwright-mcp/
