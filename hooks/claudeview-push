#!/usr/bin/env bash
#
# claudeview-push — mirror Claude Code output to the ClaudeView viewer.
#
# Claude Code hooks pass their event JSON on stdin. Pick what to show via arg:
#   claudeview-push plan          # PreToolUse, matcher = ExitPlanMode
#   claudeview-push last-message  # Stop
#
# Tabs are named <session>~<doc>, where <session> is <repo>~<branch> (from git,
# so a bare-repo + worktree layout reports the repo, not the branch-named worktree
# dir) or <topic>~<sid> outside a repo. The viewer groups by <session>, so a
# session's plan and summary sit together and different branches stay apart. The
# "~" delimiter is reserved: git forbids it in branch names and cv_clean strips it
# from every component.
#
# Delivery target (optional — a sensible local default is used otherwise):
#   CLAUDEVIEW_URL=http://host:4790   -> HTTP POST      (remote / home-lab)
#   CLAUDEVIEW_DIR=/some/dir          -> write <tab>.md  (overrides the default)
#   (neither set)                     -> write to $HOME/.claudeview
#
# Never blocks Claude: 2s curl timeout, always exits 0.

set -euo pipefail

mode="${1:-last-message}"
payload="$(cat)"

# Resolve a possibly-symlinked path to the directory that holds its target.
# Portable (GNU + BSD/macOS): follows symlink chains with plain `readlink`, since
# `readlink -f` is GNU-only. Twinned in bin/claudeview-session, which must locate
# the same lib before it can source it — so the resolver can't live in the lib.
resolve_dir() {
  local src="$1" dir
  while [ -L "$src" ]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    case "$src" in /*) ;; *) src="$dir/$src" ;; esac
  done
  cd -P "$(dirname "$src")" && pwd
}

# The session key groups this session's documents in the viewer: <repo>~<branch>
# in a git repo, else <topic>~<sid>. The identity helpers live in a shared lib so
# the hook and bin/claudeview-session can never derive different keys.
# shellcheck source=hooks/claudeview-lib.sh
source "$(resolve_dir "${BASH_SOURCE[0]}")/claudeview-lib.sh"

cwd="$(printf '%s' "$payload" | jq -r '.cwd // empty')"

# Outside a git repo there is no branch, so a short slice of the session id keeps
# same-directory sessions apart (CLAUDEVIEW_SID_CHARS=0 drops it). In a repo the
# branch is the identity and the sid is unused — same-branch sessions group.
sid="$(printf '%s' "$payload" | jq -r '.session_id // empty')"
sid="${sid//-/}"
sid_chars="${CLAUDEVIEW_SID_CHARS:-4}"
[ "$sid_chars" -gt 0 ] && sid="${sid:0:$sid_chars}" || sid=""

session="$(cv_session_key "$cwd" "$sid")"

case "$mode" in
  plan)
    tab="${session}~plan"
    md="$(printf '%s' "$payload" | jq -r '.tool_input.plan // empty')"
    ;;

  last-message)
    tab="${session}~summary"
    # The Stop hook can fire while Claude Code is still flushing the turn's final
    # message to the transcript; read too early and we mirror the previous
    # (lead-in) block instead of the real answer. Settle briefly so the last
    # block is on disk. This narrows the race but cannot close it — the
    # file-write convention (see ~/.claude/CLAUDE.md) is the reliable path.
    sleep "${CLAUDEVIEW_SETTLE:-0.5}"
    transcript="$(printf '%s' "$payload" | jq -r '.transcript_path // empty')"
    if [ -n "$transcript" ] && [ -f "$transcript" ]; then
      # The newest prose the assistant left on screen this turn — the wrap-up,
      # findings or review. A turn's final entry is almost always a tool_use, so
      # we can't take the last *message* (that skips every tool-ending turn, i.e.
      # nearly all of them). We take the last *text* block since the most recent
      # genuine user prompt: real prompts have string content, whereas tool
      # results are user entries with array content.
      md="$(jq -rs '
        ( [ range(0; length) as $i
            | select(.[$i].type == "user" and (.[$i].message.content | type == "string"))
            | $i ] | last ) as $start
        | .[$start + 1:]
        | map(select(.type == "assistant") | .message.content[]
              | select(.type == "text") | .text)
        | last // ""
      ' "$transcript" 2>/dev/null || true)"
    else
      md=""
    fi
    ;;

  *)
    exit 0
    ;;
esac

# Breadcrumb: record every invocation and its outcome, so a viewer that stays
# dark is diagnosable with `tail ~/.claudeview/.push.log` instead of a hunt. The
# name is dotted, so the watcher (which tracks only *.md) ignores it.
log_file="${CLAUDEVIEW_LOG:-$HOME/.claudeview/.push.log}"
log() {
  mkdir -p "$(dirname "$log_file")" 2>/dev/null || true
  printf '%s  mode=%-12s tab=%-12s chars=%-5s %s\n' \
    "$(date +%FT%T%z)" "$mode" "$tab" "${#md}" "$1" >>"$log_file" 2>/dev/null || true
}

# Only mirror long-format text — skip trivial tails like "Done." Tune the floor
# with CLAUDEVIEW_MIN_CHARS (~200 chars is a paragraph, "more than a few
# sentences"). The plan mode always pushes; the floor applies to messages only.
if [ "$mode" = "last-message" ]; then
  min="${CLAUDEVIEW_MIN_CHARS:-200}"
  if [ "${#md}" -lt "$min" ]; then
    log "skip: below-min (${#md}<${min})"
    exit 0
  fi
else
  if [ -z "${md:-}" ]; then
    log "skip: empty"
    exit 0
  fi
fi

if [ -n "${CLAUDEVIEW_URL:-}" ]; then
  if printf '%s' "$md" |
    curl -sS -m 2 -X POST "${CLAUDEVIEW_URL%/}/push?tab=${tab}" --data-binary @- \
      >/dev/null 2>&1; then
    log "posted -> ${CLAUDEVIEW_URL%/}/push?tab=${tab}"
  else
    log "post-failed -> ${CLAUDEVIEW_URL%/}"
  fi
else
  dir="${CLAUDEVIEW_DIR:-$HOME/.claudeview}"
  mkdir -p "$dir"
  printf '%s' "$md" >"${dir}/${tab}.md"
  log "written -> ${dir}/${tab}.md"
fi

exit 0
