# Consistent formatting across editors, no tooling required.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Elm's canonical style (elm-format) is four spaces.
[*.elm]
indent_size = 4

# Markdown uses two trailing spaces for hard line breaks.
[*.md]
trim_trailing_whitespace = false
